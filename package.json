{
  "name": "demo-auth-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "server:3001": "PORT=3001 node server/index.js",
    "db:setup": "node server/setupDatabase.js",
    "db:add-admin-role": "mysql -h 127.0.0.1 -P 3306 -u root -p care_portal < database/add-admin-role.sql",
    "db:add-profile-image": "mysql -h 127.0.0.1 -P 3306 -u root -p care_portal < database/add-profile-image.sql",
    "start": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "koa": "^2.15.4",
    "mysql2": "^3.12.0",
    "vite": "^6.1.0",
    "vue": "^3.5.13"
  }
}
